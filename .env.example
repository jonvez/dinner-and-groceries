# Supabase — public client config.
# Copy to `.env.local` (gitignored) and fill in. NEVER commit real secrets.
#
# Local dev (Supabase CLI/Docker): run `npm run db:status` to print the values
# below. The local anon key + URL are well-known, non-secret CLI defaults and
# are safe to use as-is for local development.
#
# Prod: get these from the hosted Supabase project's API settings (Project URL
# + anon/publishable key). Do NOT put them here — set them in your deploy
# environment (GCP Secret Manager → Cloud Run, per ADR 0003).

# The Supabase project URL (local default shown).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# The anon (publishable) key. RLS-protected, browser-safe.
# Local CLI default below; replace with the hosted anon key in prod.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# NOTE (ADR 0003): there is intentionally NO SUPABASE_SERVICE_ROLE_KEY here.
# M0/M1 do all data access as the signed-in user so RLS is always in force.
# The service-role key is reserved for the M2 extraction insert path and will
# be added (and audited) then.
